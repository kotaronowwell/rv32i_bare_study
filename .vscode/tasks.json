{
    "version": "2.0.0",

    "tasks": [
        {
            "label": "build",

            "type": "shell",

            "command": "cmake --build build",

            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "qemu-gdb",

            "type": "shell",

            "isBackground": true,

            "command": "qemu-system-riscv32 -machine virt -bios none -kernel build/hello -nographic -S -gdb tcp::1234",

            "problemMatcher": []
        }
    ]
}