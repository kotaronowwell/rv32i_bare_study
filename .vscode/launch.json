{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Attach QEMU RV32",

            "type": "cppdbg",
            "request": "launch",

            "program": "${workspaceFolder}/build/hello",

            "cwd": "${workspaceFolder}",

            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb-multiarch",

            "miDebuggerServerAddress": "localhost:1234",

            "stopAtEntry": true,

            "setupCommands": [
                {
                    "text": "set architecture riscv:rv32"
                }
            ]
        }
    ]
}